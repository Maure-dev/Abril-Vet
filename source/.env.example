# ─────────────────────────────────────────────────────────────
# Frontend (PÚBLICAS) — prefijo ENV_, se embeben en el bundle de Vite.
# Config web del proyecto Firebase (Console → Configuración del proyecto → Tus apps).
# ─────────────────────────────────────────────────────────────
ENV_FIREBASE_API_KEY=
ENV_FIREBASE_AUTH_DOMAIN=
ENV_FIREBASE_PROJECT_ID=
ENV_FIREBASE_STORAGE_BUCKET=
ENV_FIREBASE_MESSAGING_SENDER_ID=
ENV_FIREBASE_APP_ID=

# Cloudinary — subida de archivos (fotos, estudios, PDFs) gratuita. Reemplaza a Firebase
# Storage (que requiere plan Blaze). Console → Settings → Upload → Add upload preset
# (Signing Mode: Unsigned). La subida va directo desde el navegador, sin secretos.
ENV_CLOUDINARY_CLOUD_NAME=
ENV_CLOUDINARY_UPLOAD_PRESET=

# URL base de la API (Vercel Functions) para recordatorios (email/WhatsApp) y otros.
# En dev, si dejás esto vacío, los services pegan al proxy /api del vite.config.
ENV_API_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Servidor (SECRETOS) — cargar SOLO en Vercel (Environment Variables).
# NUNCA con prefijo ENV_ y NUNCA importadas desde source/ (no deben entrar al bundle).
# Las consumen únicamente las Vercel Functions en /api.
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=        # Service account de Firebase (JSON crudo o base64). Lo usan las Functions de /api (Admin SDK): crear/deshabilitar usuarios de Personal.
APP_BASE_URL=https://tu-dominio.vercel.app   # Base para links de recordatorios y callbacks
RESEND_API_KEY=                  # Envío de email (invitaciones de Personal, recordatorios). Opcional.
RESEND_FROM=Abril Vet <no-reply@tu-dominio.com>   # Remitente de los emails (dominio verificado en Resend)
WHATSAPP_API_TOKEN=              # Integración futura de recordatorios por WhatsApp
