rules_version = "2";

// ─────────────────────────────────────────────────────────────
// Reglas base de Storage — adjuntos clínicos (fotos de pacientes,
// estudios, PDFs, resultados de laboratorio). Sólo personal autenticado.
// Ajustá los límites de tamaño/tipo por carpeta cuando definas cada módulo.
// ─────────────────────────────────────────────────────────────
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() &&
        request.auth.token.role in ["admin", "vet", "receptionist", "assistant"];
    }

    match /{allPaths=**} {
      allow read: if isStaff();
      allow write: if isStaff() && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
